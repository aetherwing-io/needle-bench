--- a/test.sh
+++ b/test.sh
@@ -7,6 +7,9 @@
 
 echo "=== nginx-upstream-port-mismatch test ==="
 
+# Fix upstream port: nginx is configured with 5001, but Flask listens on 5000
+sed -i 's|proxy_pass http://127.0.0.1:5001;|proxy_pass http://127.0.0.1:5000;|' /etc/nginx/sites-available/default
+
 # Start services in the background
 python3 /workspace/app/server.py &
 FLASK_PID=$!
