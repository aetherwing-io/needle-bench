---
interface Props {
  title: string;
  description?: string;
  jsonLd?: Record<string, any>;
}

const { title, description = 'An open benchmark where developers submit real bugs as frozen Docker snapshots and AI agents find the needle.', jsonLd } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = `https://needle-bench.cc${currentPath}`;
const ogImage = 'https://needle-bench.cc/og-default.png';

const navLinks = [
  { href: '/', label: 'Leaderboard' },
  { href: '/insights/', label: 'Insights' },
  { href: '/contribute/', label: 'Contribute' },
  { href: '/about/', label: 'About' },
  { href: 'https://github.com/os-tack/find-the-needle', label: 'GitHub', external: true },
];

function isActive(href: string): boolean {
  if (href.startsWith('http')) return false;
  if (href === '/') return currentPath === '/' || currentPath === '/leaderboard' || currentPath === '/leaderboard/';
  return currentPath.startsWith(href);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl}>

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalUrl}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:site_name" content="needle-bench">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  <!-- JSON-LD: WebSite (all pages) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "needle-bench",
    "url": "https://needle-bench.cc",
    "description": "An open benchmark for AI coding agents. Real bugs. Deterministic scoring."
  })} />

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <script defer data-domain="needle-bench.cc" src="https://plausible.io/js/script.outbound-links.js"></script>
</head>
<body>
  <nav class="topnav">
    <a href="/" class="brand">needle-bench</a>
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={[{ active: isActive(link.href) }]}
        {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {link.label}{link.external ? ' ↗' : ''}
      </a>
    ))}
  </nav>

  <slot />

  <footer>
    <a href="https://github.com/os-tack/find-the-needle">needle-bench</a> &middot; MIT &middot; <a href="https://ostk.ai">ostk.ai</a>
  </footer>
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  .brand-sub {
    font-weight: 400;
    font-size: 0.7em;
    color: var(--text-muted);
    margin-left: 0.3em;
  }

  .nav-sep {
    color: var(--border);
    user-select: none;
  }
</style>
